# Server configuration
PORT=3003

# Contract configuration
CONTRACT_ADDRESS=deployed_contract_address_here
RPC_URL=http://127.0.0.1:8545

# Webhook system (optional but recommended)
# Protect webhook management endpoints with x-api-key header
ADMIN_API_KEY=change_me_admin_key
# Default signing secret used if a webhook is registered without its own secret
WEBHOOK_SIGNING_SECRET=change_me_webhook_secret
# Delivery behavior
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_RETRY_BASE_MS=1500

# Optional: For production deployments
INFURA_PROJECT_ID=your_infura_project_id
PRIVATE_KEY=your_private_key_here
